{
  "expo": {
    "name": "DV SPORTS",
    "slug": "dv-sports",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F7F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dvsports.app"
    },
    "android": {
      "package": "com.dvsports.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
